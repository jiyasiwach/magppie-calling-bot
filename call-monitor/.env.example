# The one URL the screen needs. When unset, the app runs the scripted
# demo call (src/lib/demoCall.ts) so the whole screen works offline.
# When set, the screen opens this websocket, listens, and paints — and
# sends back only takeover.request / takeover.release.
NEXT_PUBLIC_WS_URL=
# e.g. NEXT_PUBLIC_WS_URL=wss://calls.mymagppie.com/ws/monitor

# Zoho CRM — read by /api/leads for the leads panel in the rail.
# Leave unset and the panel serves the committed snapshot of the real org
# (src/lib/leads.ts), labelling itself "snapshot" instead of "live".
#
# Create a Self Client at https://api-console.zoho.in with scope
#   ZohoCRM.modules.leads.READ
# then exchange the grant code for a refresh token.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Magppie's org is on the India data centre, which is the default.
# Only set these if that ever changes.
# ZOHO_ACCOUNTS_HOST=https://accounts.zoho.in
# ZOHO_API_HOST=https://www.zohoapis.in
